# mock 데이터로 동작 (true 또는 미설정 = mock). 실 연동 시 false 로 변경
VITE_USE_MOCK=true
# 실 백엔드 base URL (VITE_USE_MOCK=false 일 때 사용)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Supabase Auth (VITE_USE_MOCK=false 일 때 로그인에 필요) ---
# 프론트는 GoTrue 로 직접 로그인해 access_token 을 발급받는다.
# 반드시 anon/publishable(공개용) 키만 사용 — service_role 키는 절대 넣지 말 것.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
