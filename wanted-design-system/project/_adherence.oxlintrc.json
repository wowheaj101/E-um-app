{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/icons/**",
              "components/navigation/**",
              "ui_kits/wanted/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|name|shape|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, name, shape, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:rounded|circle)$/]",
        "message": "<Avatar> shape must be one of 'rounded' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|max|dot|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: count, max, dot, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:negative|primary|neutral)$/]",
        "message": "<Badge> tone must be one of 'negative' | 'primary' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|size|leadingIcon|trailingIcon|fullWidth|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, tone, size, leadingIcon, trailingIcon, fullWidth, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|weak|outline|text)$/]",
        "message": "<Button> variant must be one of 'solid' | 'weak' | 'outline' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|neutral|negative)$/]",
        "message": "<Button> tone must be one of 'primary' | 'neutral' | 'negative'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:elevation|padding|radius|interactive|as|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: elevation, padding, radius, interactive, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:flat|raised|floating|none)$/]",
        "message": "<Card> elevation must be one of 'flat' | 'raised' | 'floating' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|label|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, label, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Checkbox> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|selected|disabled|leadingIcon|trailingIcon|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: size, selected, disabled, leadingIcon, trailingIcon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm|xs)$/]",
        "message": "<Chip> size must be one of 'lg' | 'md' | 'sm' | 'xs'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContentBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|size|style|key|ref|className|style|children)$/]",
        "message": "<ContentBadge> doesn't accept that prop. Declared props: tone, variant, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContentBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|violet|green|red|orange|cyan|pink|neutral)$/]",
        "message": "<ContentBadge> tone must be one of 'blue' | 'violet' | 'green' | 'red' | 'orange' | 'cyan' | 'pink' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContentBadge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:weak|solid)$/]",
        "message": "<ContentBadge> variant must be one of 'weak' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContentBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<ContentBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|title|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:home|search|bookmark|bell|person|message|heart|plus|share|setting|filter|location|pin|clock|coins|calendar|chevronDown|chevronLeft|chevronRight|check|close|circleCheck|circleInfo|circleExclamation|triangleExclamation|trash|globe|squareMore)$/]",
        "message": "<Icon> name must be one of 'home' | 'search' | 'bookmark' | 'bell' | 'person' | 'message' | 'heart' | 'plus' | 'share' | 'setting' | 'filter' | 'location' | 'pin' | 'clock' | 'coins' | 'calendar' | 'chevronDown' | 'chevronLeft' | 'chevronRight' | 'check' | 'close' | 'circleCheck' | 'circleInfo' | 'circleExclamation' | 'triangleExclamation' | 'trash' | 'globe' | 'squareMore'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|tone|size|disabled|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, tone, size, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|text)$/]",
        "message": "<IconButton> variant must be one of 'solid' | 'outline' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|neutral|negative)$/]",
        "message": "<IconButton> tone must be one of 'primary' | 'neutral' | 'negative'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<IconButton> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|leading|trailing|divider|disabled|style|key|ref|className|style|children)$/]",
        "message": "<ListCell> doesn't accept that prop. Declared props: title, description, leading, trailing, divider, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|value|name|label|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, value, name, label, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Radio> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Switch> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|count|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|helper|error|size|leading|trailing|style|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, helper, error, size, leading, trailing, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<TextField> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|icon|action|onAction|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: status, icon, action, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:neutral|positive|negative|info)$/]",
        "message": "<Toast> status must be one of 'neutral' | 'positive' | 'negative' | 'info'."
      }
    ]
  },
