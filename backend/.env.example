# 이음(E-UM) Backend 환경변수 예시
# 실제 값은 .env 로 복사 후 채울 것 (.env 는 .gitignore 처리됨)

APP_NAME=이음(E-UM) API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# --- Supabase (PostgREST + Auth, httpx 직접 호출) ---
# SUPABASE_URL: 프로젝트 REST 엔드포인트 (https://<ref>.supabase.co)
SUPABASE_URL=https://your-ref.supabase.co
SUPABASE_ANON_KEY=          # Project Settings > API > anon public
SUPABASE_SERVICE_ROLE_KEY=  # 동 service_role (RLS 우회: 이메일 조회/시스템 기록)
SUPABASE_JWT_SECRET=        # 동 JWT Secret (HS256 토큰 검증)

# --- Gemini (음성/OCR 파싱) ---
GEMINI_API_KEY=             # https://aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-2.5-flash

# --- 디지털 유산 AES 암호화 키 ---
# 권장: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LEGACY_ENCRYPTION_KEY=
