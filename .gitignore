# --- 비밀정보 (절대 커밋 금지) ---
.env
.env.*
*.env
supabase/.env
# 레거시 안전망: DB 비밀번호는 이제 .env(SUPABASE_DB_URL)로 통합됨. 재생성 차단용으로 유지.
DBpw.md
# 로컬 권한 설정 — 접속 문자열/비밀번호 포함 가능
.claude/settings.local.json

# 템플릿(.env.example)은 커밋 허용
!.env.example
!**/.env.example

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/

# --- Node / Vue (프론트 추가 시) ---
node_modules/
dist/
.vite/

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
*.log
